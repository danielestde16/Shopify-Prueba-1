{%- comment -%}
  Cuenta regresiva "Envío gratis hoy" — termina al final del día y se renueva
  sola cada medianoche. El JS está centralizado en theme.liquid (busca todos
  los [data-countdown]). Variante de color con: {% render 'kinu-countdown', theme: 'light' %}
{%- endcomment -%}
<div class="kinu-cd kinu-cd--{{ theme | default: 'dark' }}" role="status" aria-label="Envío gratis termina hoy" data-countdown>
  <span class="kinu-cd__ship">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span>Envío <strong>GRATIS</strong> hoy</span>
  </span>
  <div class="kinu-cd__clock">
    <span class="kinu-cd__box"><b data-cd-h>00</b><i>h</i></span>
    <span class="kinu-cd__sep">:</span>
    <span class="kinu-cd__box"><b data-cd-m>00</b><i>min</i></span>
    <span class="kinu-cd__sep">:</span>
    <span class="kinu-cd__box"><b data-cd-s>00</b><i>seg</i></span>
  </div>
</div>

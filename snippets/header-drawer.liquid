{% comment %}
  KINU — Menú móvil personalizado
  Drawer con: producto, combo, links de sección
{% endcomment %}

{%- assign kinu_product = collections.all.products.first -%}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div id="menu-drawer" class="menu-drawer motion-reduce">
      <div class="menu-drawer__inner-container">
        <div class="kinu-nav">

          <!-- -- Nuestro Magnesio -- -->
          <p class="kinu-nav__label">Nuestro Magnesio</p>

          <a href="{{ kinu_product.url | default: '/products' }}"
             class="kinu-nav__product js-kinu-nav-close">
            {%- if kinu_product.featured_image -%}
              <img
                src="{{ kinu_product.featured_image | image_url: width: 140 }}"
                alt="{{ kinu_product.title | escape }}"
                width="70" height="70"
                loading="lazy"
                class="kinu-nav__product-img">
            {%- endif -%}
            <div class="kinu-nav__product-info">
              <strong class="kinu-nav__product-name">{{ kinu_product.title | default: 'KINU Magnesio' }}</strong>
              <p class="kinu-nav__product-desc">Citrato de magnesio puro · 110 noches de calma profunda</p>
            </div>
            <span class="kinu-nav__arrow" aria-hidden="true">-></span>
          </a>

          <div class="kinu-nav__sep"></div>

          <!-- -- Crea tu combo -- -->
          <a href="/#kinu-bundles" class="kinu-nav__combo js-kinu-nav-close">
            <span class="kinu-nav__combo-text">
              <strong>Crea tu combo</strong>
              <small>Elige tu pack con ahorro</small>
            </span>
            <span class="kinu-nav__arrow" aria-hidden="true">-></span>
          </a>

          <div class="kinu-nav__sep"></div>

          <!-- -- Links de sección -- -->
          <nav class="kinu-nav__sections" aria-label="Secciones de la página">
            <a href="/#kinu-beneficios" class="kinu-nav__link js-kinu-nav-close">Beneficios</a>
            <a href="/#kinu-formula"    class="kinu-nav__link js-kinu-nav-close">Nuestra fórmula</a>
            <a href="/#kinu-reviews"    class="kinu-nav__link js-kinu-nav-close">Testimonios</a>
          </nav>

        </div><!-- /.kinu-nav -->
      </div>
    </div>

  </details>
</header-drawer>

<script>
(function () {
  function init() {
    var drawer = document.getElementById('Details-menu-drawer-container');
    if (!drawer) return;
    /* Cierra el menú al hacer click en cualquier enlace interno */
    drawer.querySelectorAll('.js-kinu-nav-close').forEach(function (el) {
      el.addEventListener('click', function () {
        drawer.removeAttribute('open');
        document.body.style.overflow = '';
        document.body.classList.remove('overflow-hidden-tablet', 'overflow-hidden-desktop');
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

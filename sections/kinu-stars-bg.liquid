<script>
(function () {
  var starfield = document.getElementById('kinu-starfield');
  if (!starfield) return;

  var fadeStart = 0;
  var fadeEnd   = 0;

  function calcPositions() {
    var hero     = document.querySelector('.kinu-hero-section');
    var problema = document.querySelector('.kinu-problema-section');
    var valor    = document.querySelector('.kinu-valor-section');
    var endEl    = problema || valor;
    if (!hero || !endEl) return;

    fadeStart = hero.offsetTop + hero.offsetHeight * 0.4;
    fadeEnd   = endEl.offsetTop + endEl.offsetHeight;
  }

  function updateOpacity() {
    if (!fadeEnd) return;
    var scrollY  = window.pageYOffset;
    var opacity;

    if (scrollY <= fadeStart) {
      opacity = 0.45;
    } else if (scrollY >= fadeEnd) {
      opacity = 0;
    } else {
      opacity = 0.45 * (1 - (scrollY - fadeStart) / (fadeEnd - fadeStart));
    }

    starfield.style.opacity = opacity;
  }

  function init() {
    calcPositions();
    updateOpacity();
  }

  window.addEventListener('scroll', updateOpacity, { passive: true });
  window.addEventListener('resize', init,          { passive: true });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


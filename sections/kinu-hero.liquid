        <circle cx="258" cy="252" r="2.0" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.85" class="kinu-star--twinkle-slow"/>
        <circle cx="148" cy="400" r="2.4" fill="#F0F4FD" filter="url(#kinu-glow)" opacity="0.90"/>
        <circle cx="295" cy="388" r="3.0" fill="#F0F4FD" filter="url(#kinu-glow)" opacity="0.95"/>
      </g>

      <!-- ══════════════════════════════════════════
           CONSTELACIÓN 2: OSA MAYOR (inferior izquierda)
           ══════════════════════════════════════════ -->
      <g>
        <g stroke="#F0F4FD" stroke-width="0.7" opacity="0.22" fill="none">
          <!-- Mango -->
          <line x1="148" y1="650" x2="210" y2="625"/>
          <line x1="210" y1="625" x2="278" y2="612"/>
          <line x1="278" y1="612" x2="342" y2="602"/>

{{ 'kinu-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  if section.settings.product != blank
    assign hero_product = section.settings.product
  else
    assign hero_product = collections.all.products.first
  endif
  assign logo_url = 'https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Logo_Kinu_Letras_Blancas_sin_fondo.png?v=1780025964'
-%}

<section class="kinu-hero">

  <!-- ── Estrella fugaz (fuera del contenedor que clipa las estrellas) ── -->
  <div class="kinu-hero__shoot" aria-hidden="true"></div>

  <!-- ── Universo: clipeado para no salir del hero ── -->
  <div class="kinu-hero__sky-container" aria-hidden="true">
  <div class="kinu-hero__sky">
    <svg class="kinu-hero__stars-svg" viewBox="0 0 1400 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="kinu-glow-xl" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="5" result="blur"/>
          <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="kinu-glow" x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="2.5" result="blur"/>
          <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="kinu-glow-soft" x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="1.5" result="blur"/>
          <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <!-- ── Estrellas de fondo (60+) ─────────────────────── -->

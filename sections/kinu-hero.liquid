        <circle cx="1270" cy="435" r="2.4" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.90"/>
        <circle cx="1250" cy="470" r="2.0" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.85" class="kinu-star--twinkle"/>
        <circle cx="1225" cy="478" r="2.2" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.88"/>

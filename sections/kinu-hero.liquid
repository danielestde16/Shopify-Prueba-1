      <!-- ══════════════════════════════════════════
           CONSTELACIÓN 7: PLÉYADES (derecha inferior, cúmulo)
           ══════════════════════════════════════════ -->
      <g>
        <circle cx="1188" cy="465" r="2.4" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.90" class="kinu-star--twinkle-slow"/>

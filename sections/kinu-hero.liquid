{{ 'kinu-hero.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="image" fetchpriority="high"
      href="https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Foto_Tarro_Transparente.png?v=1780027313&width=700">

{%- liquid
  if section.settings.product != blank
    assign hero_product = section.settings.product
  else
    assign hero_product = collections.all.products.first
  endif
  assign logo_url = 'https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Logo_Kinu_Letras_Blancas_sin_fondo.png?v=1780025964'
  assign hero_video = section.settings.hero_video_url | default: 'https://cdn.shopify.com/videos/c/o/v/1e1d98b176be4392aef751a982c27afd.mp4'
  assign hero_poster = 'https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Fotograma_Video_Header.png?v=1780723005&width=1200'
-%}

<section class="kinu-hero">

  <!-- -- Video de fondo galaxia — loop infinito -- -->
  <video
    class="kinu-hero__video"
    loop
    muted
    playsinline
    webkit-playsinline
    preload="none"
    disablepictureinpicture
    disableremoteplayback
    poster="{% if section.settings.video_poster != blank %}{{ section.settings.video_poster | image_url: width: 1200 }}{% else %}{{ hero_poster }}{% endif %}"
    aria-hidden="true">
    <source data-src="{{ hero_video }}" type="video/mp4">
  </video>

  <div class="kinu-hero__inner">

    <div class="kinu-hero__content">
      <a href="{{ routes.root_url }}" class="kinu-hero__logo-link">
        <img
          src="{{ logo_url }}"
          alt="KINU"
          class="kinu-hero__logo"
          width="130"
          height="52"
          loading="eager"
        >
      </a>

      <span class="kinu-hero__kicker">El ritual de la calma</span>

      <h1 class="kinu-hero__headline">
        Apaga la cabeza.<br>Vuelve a dormir.
      </h1>

      <p class="kinu-hero__subhead">
        Relaja el cuerpo. Calma la mente. Sin atontamiento.
      </p>

      <div class="kinu-hero__props">
        <div class="kinu-hero__prop">
          <span class="kinu-hero__prop-ico" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="2"/><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/></svg>
          </span>
          <span class="kinu-hero__prop-lbl">1 ingrediente</span>
        </div>
        <div class="kinu-hero__prop">
          <span class="kinu-hero__prop-ico" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><path d="M24 6 C24 6 10 22 10 32 A14 14 0 0 0 38 32 C38 22 24 6 24 6Z"/><path d="M16 31 C16 28 15 26 15 24" opacity="0.5"/></svg>
          </span>
          <span class="kinu-hero__prop-lbl">Sin sabor</span>
        </div>
        <div class="kinu-hero__prop">
          <span class="kinu-hero__prop-ico" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
          </span>
          <span class="kinu-hero__prop-lbl">Sin aditivos</span>
        </div>
        <div class="kinu-hero__prop">
          <span class="kinu-hero__prop-ico" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
          <span class="kinu-hero__prop-lbl">110 noches de calma</span>
        </div>
      </div>

      <a href="{{ hero_product.url | default: '#' }}" class="kinu-hero__cta kinu-fill-btn">
        Quiero dormir mejor
      </a>
    </div>

    <div class="kinu-hero__media">
      <img
        src="https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Foto_Tarro_Transparente.png?v=1780027313&width=700"
        alt="KINU Citrato de Magnesio en Polvo"
        class="kinu-hero__product-img"
        width="500"
        height="500"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      >
    </div>

  </div>
</section>

<script>
(function () {
  var v = document.querySelector('.kinu-hero__video');
  if (!v) return;
  /* Silenciado (requisito para autoplay en móvil) */
  v.muted = true;
  v.setAttribute('muted', '');

  function play() {
    var p = v.play();
    if (p && p.catch) p.catch(function () {});
  }

  /* Carga el video SOLO después del primer pintado, para no robarle
     ancho de banda a la imagen/texto principal (mejora el LCP). */
  function loadVideo() {
    var src = v.querySelector('source[data-src]');
    if (src && !src.getAttribute('src')) {
      src.setAttribute('src', src.getAttribute('data-src'));
      v.load();
    }
    play();
  }
  function deferLoad() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadVideo, { timeout: 2500 });
    } else {
      setTimeout(loadVideo, 1200);
    }
  }
  if (document.readyState === 'complete') {
    deferLoad();
  } else {
    window.addEventListener('load', deferLoad, { once: true });
  }

  /* Reintenta al primer toque/scroll y al volver a la pestaña */
  ['touchstart', 'click', 'scroll'].forEach(function (ev) {
    window.addEventListener(ev, play, { once: true, passive: true });
  });
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden) play();
  });
})();
</script>

{% schema %}
{
  "name": "KINU Hero",
  "tag": "section",
  "class": "kinu-hero-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto KINU"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Poster del video (galaxia)",
      "info": "Sube un fotograma de la galaxia. Se muestra mientras el video carga, evita el parpadeo en móvil."
    },
    {
      "type": "text",
      "id": "hero_video_url",
      "label": "URL del video de fondo",
      "info": "Sube el video comprimido en Configuración → Archivos, copia el enlace y pégalo aquí. Vacío = usa el video actual."
    }
  ],
  "presets": [
    {
      "name": "KINU Hero"
    }
  ]
}
{% endschema %}

        <circle cx="850"  cy="38"  r="1.1" opacity="0.52"/>
        <circle cx="968"  cy="20"  r="0.7" opacity="0.32"/>
        <circle cx="1038" cy="52"  r="0.9" opacity="0.44"/>
        <circle cx="1128" cy="18"  r="0.8" opacity="0.36"/>
        <circle cx="1195" cy="42"  r="1.0" opacity="0.50"/>
        <circle cx="1355" cy="28"  r="0.9" opacity="0.42"/>
        <!-- Fila 2 -->
        <circle cx="28"   cy="148" r="0.8" opacity="0.35"/>
        <circle cx="92"   cy="172" r="1.0" opacity="0.48"/>
        <circle cx="220"  cy="158" r="0.7" opacity="0.32"/>
        <circle cx="378"  cy="182" r="0.9" opacity="0.44"/>
        <circle cx="432"  cy="145" r="0.8" opacity="0.38"/>
        <circle cx="490"  cy="168" r="1.1" opacity="0.52"/>

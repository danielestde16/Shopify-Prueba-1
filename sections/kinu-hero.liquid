{{ 'kinu-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  if section.settings.product != blank
    assign hero_product = section.settings.product
  else
    assign hero_product = collections.all.products.first
  endif
  assign logo_url = 'https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Logo_Kinu_Letras_Blancas_sin_fondo.png?v=1780025964'
-%}

<section class="kinu-hero">

  <!-- -- Estrella fugaz — CSS puro, clipeada al hero -- -->
  <div class="kinu-hero__shoot" aria-hidden="true"></div>

  <div class="kinu-hero__inner">

    <div class="kinu-hero__content">
      <a href="{{ routes.root_url }}" class="kinu-hero__logo-link">
        <img
          src="{{ logo_url }}"
          alt="KINU"
          class="kinu-hero__logo"
          width="130"
          height="52"
          loading="eager"
        >
      </a>

      <h1 class="kinu-hero__headline">
        Magnesio puro para mentes que no se apagan.
      </h1>

      <p class="kinu-hero__sub">
        Un solo ingrediente &middot; Sin sabor &middot; Sin aditivos<br>
        110 noches de calma profunda.
      </p>

      <a href="{{ hero_product.url | default: '#' }}" class="kinu-hero__cta kinu-fill-btn">
        Quiero mi KINU
      </a>
    </div>

    <div class="kinu-hero__media">
      <img
        src="https://cdn.shopify.com/s/files/1/1000/7435/7034/files/Foto_Tarro_Transparente.png?v=1780027313"
        alt="KINU Citrato de Magnesio en Polvo"
        class="kinu-hero__product-img"
        width="500"
        height="500"
        loading="eager"
      >
    </div>

  </div>
</section>

{% schema %}
{
  "name": "KINU Hero",
  "tag": "section",
  "class": "kinu-hero-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto KINU"
    }
  ],
  "presets": [
    {
      "name": "KINU Hero"
    }
  ]
}
{% endschema %}

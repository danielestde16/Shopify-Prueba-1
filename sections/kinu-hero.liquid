          <line x1="548" y1="505" x2="540" y2="448"/>
          <line x1="540" y1="448" x2="510" y2="390"/>
          <line x1="510" y1="390" x2="505" y2="330"/>
          <line x1="505" y1="330" x2="568" y2="355"/>
          <line x1="568" y1="355" x2="510" y2="390"/>
          <!-- Cuerpo y cola -->
          <line x1="548" y1="505" x2="658" y2="492"/>
          <line x1="658" y1="492" x2="688" y2="448"/>
        </g>
        <circle cx="548" cy="505" r="3.0" fill="#F0F4FD" filter="url(#kinu-glow)" opacity="0.98" class="kinu-star--twinkle-slow"/>
        <circle cx="540" cy="448" r="2.0" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.85"/>
        <circle cx="510" cy="390" r="2.2" fill="#F0F4FD" filter="url(#kinu-glow-soft)" opacity="0.88"/>

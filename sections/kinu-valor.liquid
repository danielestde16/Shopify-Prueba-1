<script>
(function () {
  var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var kvEl    = document.querySelector('.kinu-v2');
  var desktop = document.querySelector('.kinu-v2__desktop');

  /* -- Fade-in título -- */
  var heroTitle = document.querySelector('.js-kv-title');
  if (heroTitle) {
    if (REDUCED || typeof IntersectionObserver === 'undefined') {
      heroTitle.classList.add('is-visible');
    } else {
      var tObs = new IntersectionObserver(function (e) {
        if (e[0].isIntersecting) { heroTitle.classList.add('is-visible'); tObs.disconnect(); }
      }, { threshold: 0.15 });
      tObs.observe(heroTitle);
    }
  }

  /* -- Tabs desktop -- */
  if (desktop) {
    var tabs   = Array.prototype.slice.call(desktop.querySelectorAll('.kinu-v2__tab'));
    var panels = Array.prototype.slice.call(desktop.querySelectorAll('.kinu-v2__panel-content'));
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(function (p) { p.classList.remove('is-active'); });
        tab.classList.add('is-active'); tab.setAttribute('aria-selected', 'true');
        var p = document.getElementById(tab.dataset.target);
        if (p) p.classList.add('is-active');
      });
    });
  }

  /* -- Cards móvil -- */
  var mobile = document.querySelector('.kinu-v2__mobile');
  var mAttrs = mobile ? Array.prototype.slice.call(mobile.querySelectorAll('.kinu-v2__m-attr')) : [];
  if (mobile && mAttrs.length) {
    if (REDUCED) { mAttrs.forEach(function (a) { a.classList.add('is-active'); }); }
    else if (typeof IntersectionObserver !== 'undefined') {
      var obs = new IntersectionObserver(function (e) {
        e.forEach(function (en) { en.target.classList.toggle('is-active', en.isIntersecting); });
      }, { threshold: 0.3, rootMargin: '-5% 0px -5% 0px' });
      mAttrs.forEach(function (a) { obs.observe(a); });
    }
  }

  /* ==============================================
     SCROLL-CAPTURE desktop
     -- Cuando la sección llena el viewport, el primer
        scroll no mueve la página sino que cambia el panel.
        El segundo scroll suelta el control y la página
        continúa normalmente.
     ============================================== */
  if (desktop && !REDUCED) {
    var showing      = 'benefits';
    var capActive    = false;
    var transitioning = false;

    function showStats() {
      showing = 'stats';
      kvEl.classList.add('kinu-v2--stats');
      desktop.querySelectorAll('.js-kv-stat').forEach(function (box) {
        box.classList.add('is-visible');
        var el = box.querySelector('.js-kv-count');
        if (el && !el._counting) countUp(el);
      });
    }

    function showBenefits() {
      showing = 'benefits';
      kvEl.classList.remove('kinu-v2--stats');
      desktop.querySelectorAll('.js-kv-stat').forEach(function (box) {
        box.classList.remove('is-visible');
        var el = box.querySelector('.js-kv-count');
        if (el) { el._counting = false; el.textContent = (el.dataset.prefix || '') + '0' + (el.dataset.suffix || ''); }
      });
    }

    /* -- Scroll lineal: el progreso en la sección determina el panel --
       La sección mide 200vh. El layout es sticky.
       El usuario scrollea a su ritmo — la animación responde al progreso:
         0 – 48 %  -> beneficios
         48 – 100% -> cifras
       Al volver (< 38%), se revierten automáticamente.
    -- */
    function onScroll() {
      if (window.innerWidth < 769) return;
      var rect     = desktop.getBoundingClientRect();
      var total    = desktop.offsetHeight - window.innerHeight;
      var scrolled = Math.max(0, -rect.top);
      var pct      = total > 0 ? scrolled / total : 0;

      if (pct >= 0.48 && showing === 'benefits') showStats();
      if (pct <  0.38 && showing === 'stats')    showBenefits();
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  /* ==============================================
     CONTADORES móvil: replay al entrar/salir viewport
     ============================================== */
  function countUp(el) {
    if (!el || el._counting) return;
    if (REDUCED) { el.textContent = (el.dataset.prefix || '') + el.dataset.target + (el.dataset.suffix || ''); return; }
    var target = parseInt(el.dataset.target, 10);
    var prefix = el.dataset.prefix || '', suffix = el.dataset.suffix || '';
    var dur = 1500, t0 = null;
    el._counting = true;
    function step(ts) {
      if (!t0) t0 = ts;
      var p = Math.min((ts - t0) / dur, 1), ease = 1 - Math.pow(1 - p, 3);
      el.textContent = prefix + Math.round(ease * target) + suffix;
      if (p < 1) requestAnimationFrame(step); else el._counting = false;
    }
    requestAnimationFrame(step);
  }

  var mobileStats = mobile ? Array.prototype.slice.call(mobile.querySelectorAll('.js-kv-stat')) : [];
  if (mobileStats.length && typeof IntersectionObserver !== 'undefined') {
    var ctObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        var el = e.target.querySelector('.js-kv-count');
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          if (el && !el._counting) countUp(el);
        } else {
          e.target.classList.remove('is-visible');
          if (el) { el._counting = false; el.textContent = (el.dataset.prefix || '') + '0' + (el.dataset.suffix || ''); }
        }
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -30px 0px' });
    mobileStats.forEach(function (b) { ctObs.observe(b); });
  }

})();
</script>


<div class="kinu-v2" role="region" aria-label="Qué hace especial a KINU">

  <!-- ══════════════════════════════════════════════════
       DESKTOP (≥ 769px)
       ══════════════════════════════════════════════════ -->
  <div class="kinu-v2__desktop">
    <div class="kinu-v2__scroll-area">
      <div class="kinu-v2__panel">

        <!-- Columna izquierda: atributos 1, 3, 5 -->
        <div class="kinu-v2__col kinu-v2__col--left">

          <div class="kinu-v2__attr" data-seq="1">
            <div class="kinu-v2__icon">{{ icon_atom }}</div>
            <h3 class="kinu-v2__title">1 solo ingrediente</h3>
            <p class="kinu-v2__desc">Citrato de magnesio puro. Sin mezclas. Sin rellenos.</p>
          </div>

          <div class="kinu-v2__attr" data-seq="3">
            <div class="kinu-v2__icon">{{ icon_moon }}</div>
            <h3 class="kinu-v2__title">110 noches</h3>
            <p class="kinu-v2__desc">Un tarro. Cuatro meses de ritual nocturno.</p>
          </div>

          <div class="kinu-v2__attr" data-seq="5">
            <div class="kinu-v2__icon">{{ icon_hex }}</div>
            <h3 class="kinu-v2__title">Citrato puro</h3>
            <p class="kinu-v2__desc">La forma de magnesio con mayor biodisponibilidad.</p>
          </div>

        </div>

        <!-- Columna central: animación 3D Spline (fondo transparente) -->
        <div class="kinu-v2__col kinu-v2__col--center">
          <div class="kinu-spline" id="kinu-spline-desktop">
            <iframe
              src="https://my.spline.design/kinudef-NRPFFaG0qACP6RXXJmzxyEml/"
              frameborder="0"
              loading="lazy"
              title="KINU Magnesio 3D"
            ></iframe>
          </div>
        </div>

        <!-- Columna derecha: atributos 2, 4 -->
        <div class="kinu-v2__col kinu-v2__col--right">

          <div class="kinu-v2__attr" data-seq="2">
            <div class="kinu-v2__icon">{{ icon_drop }}</div>
            <h3 class="kinu-v2__title">Sin sabor. Sin stevia.</h3>
            <p class="kinu-v2__desc">Se disuelve invisible en cualquier líquido. Sin comprometer nada.</p>
          </div>

          <div class="kinu-v2__attr" data-seq="4">
            <div class="kinu-v2__icon">{{ icon_scale }}</div>
            <h3 class="kinu-v2__title">280mg por porción</h3>
            <p class="kinu-v2__desc">La dosis respaldada por la ciencia.</p>
          </div>

        </div>

      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       MÓVIL (≤ 768px)
       Imagen centrada en pantalla, tarjetas debajo
       ══════════════════════════════════════════════════ -->
  <div class="kinu-v2__mobile">
    <div class="kinu-v2__m-scroll-area">

      <!-- Animación 3D Spline en la pantalla -->
      <div class="kinu-v2__m-jar">
        <div class="kinu-spline kinu-spline--mobile" id="kinu-spline-mobile">
          <iframe
            src="https://my.spline.design/kinudef-NRPFFaG0qACP6RXXJmzxyEml/"
            frameborder="0"
            loading="lazy"
            title="KINU Magnesio 3D"
          ></iframe>
        </div>
      </div>

      <!-- Atributos en flujo normal debajo del tarro sticky -->
      <div class="kinu-v2__m-attrs-flow">

        <div class="kinu-v2__m-attr" data-seq="1">
          <div class="kinu-v2__icon">{{ icon_atom }}</div>
          <h3 class="kinu-v2__title">1 solo ingrediente</h3>
          <p class="kinu-v2__desc">Citrato de magnesio puro. Sin mezclas. Sin rellenos.</p>
        </div>

        <div class="kinu-v2__m-attr" data-seq="2">
          <div class="kinu-v2__icon">{{ icon_drop }}</div>
          <h3 class="kinu-v2__title">Sin sabor. Sin stevia.</h3>
          <p class="kinu-v2__desc">Se disuelve invisible en cualquier líquido. Sin comprometer nada.</p>
        </div>

        <div class="kinu-v2__m-attr" data-seq="3">
          <div class="kinu-v2__icon">{{ icon_moon }}</div>
          <h3 class="kinu-v2__title">110 noches</h3>
          <p class="kinu-v2__desc">Un tarro. Cuatro meses de ritual nocturno.</p>
        </div>

        <div class="kinu-v2__m-attr" data-seq="4">
          <div class="kinu-v2__icon">{{ icon_scale }}</div>
          <h3 class="kinu-v2__title">280mg por porción</h3>
          <p class="kinu-v2__desc">La dosis respaldada por la ciencia.</p>
        </div>

        <div class="kinu-v2__m-attr" data-seq="5">
          <div class="kinu-v2__icon">{{ icon_hex }}</div>
          <h3 class="kinu-v2__title">Citrato puro</h3>
          <p class="kinu-v2__desc">La forma de magnesio con mayor biodisponibilidad.</p>
        </div>

      </div>

    </div>
  </div>

</div>

<script>
(function () {
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function markActive(attrs, activeSeq) {
    attrs.forEach(function (attr) {
      var seq = parseInt(attr.dataset.seq, 10);
      attr.classList.remove('is-active', 'is-past');
      if (seq === activeSeq)    attr.classList.add('is-active');
      else if (seq < activeSeq) attr.classList.add('is-past');
    });
  }

  /* ── DESKTOP: scroll progress ── */
  var desktop = document.querySelector('.kinu-v2__desktop');
  var dArea   = desktop && desktop.querySelector('.kinu-v2__scroll-area');
  var dAttrs  = desktop ? Array.from(desktop.querySelectorAll('.kinu-v2__attr')) : [];

  function updateDesktop() {
    if (!dArea || prefersReduced) return;
    var scrollY    = window.pageYOffset;
    var top        = dArea.offsetTop;
    var scrollable = dArea.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var progress  = Math.max(0, Math.min(1, (scrollY - top) / scrollable));
    var activeSeq = Math.min(Math.floor(progress * 5) + 1, 5);
    markActive(dAttrs, activeSeq);
  }

  if (desktop) {
    window.addEventListener('scroll', updateDesktop, { passive: true });
    updateDesktop();
  }

  /* ── MÓVIL: IntersectionObserver sobre cards en flujo normal ── */
  var mobile = document.querySelector('.kinu-v2__mobile');
  var mAttrs = mobile ? Array.from(mobile.querySelectorAll('.kinu-v2__m-attr')) : [];

  if (mobile && mAttrs.length) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        markActive(mAttrs, parseInt(entry.target.dataset.seq, 10));
      });
    }, {
      threshold: 0.5,
      rootMargin: '-15% 0px -15% 0px'
    });
    mAttrs.forEach(function (a) { observer.observe(a); });
  }
})();
</script>


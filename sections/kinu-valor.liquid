{%- comment -%} URL del producto para el CTA {%- endcomment -%}
{%- if section.settings.product != blank -%}
  {%- assign product_url = section.settings.product.url -%}
{%- else -%}
  {%- assign product_url = collections.all.products.first.url | default: '#' -%}
{%- endif -%}

<div class="kinu-v2" role="region" aria-label="Qué hace especial a KINU">

  <!-- ══════════════════════════════════════════════════
       DESKTOP (≥ 769px)
       2 columnas: Spline izquierda | tabs + contenido derecha
       ══════════════════════════════════════════════════ -->
  <div class="kinu-v2__desktop">
    <div class="kinu-v2__layout">

      <!-- Columna izquierda: Spline 3D -->
      <div class="kinu-v2__product-col">
        <div class="kinu-spline" id="kinu-spline-desktop">
          <iframe
            src="https://my.spline.design/kinudef-NRPFFaG0qACP6RXXJmzxyEml/"
            frameborder="0"
            loading="lazy"
            title="KINU Magnesio 3D"
          ></iframe>
        </div>
      </div>

      <!-- Columna derecha: eyebrow + título + tabs + panel + CTAs -->
      <div class="kinu-v2__content-col">

        <span class="kinu-v2__eyebrow">Citrato de magnesio puro · 110 porciones</span>

        <h2 class="kinu-v2__hero-title js-kv-title">
          Magnesio puro para mentes<br>que no se apagan.
        </h2>

        <!-- Selector de beneficios (tabs) -->
        <div class="kinu-v2__tabs" role="tablist" aria-label="Beneficios KINU">

          <button class="kinu-v2__tab is-active"
                  data-target="kv-tab-1"
                  role="tab" aria-selected="true" aria-controls="kv-tab-1">
            <span class="kinu-v2__tab-icon">{{ icon_atom }}</span>
            <span class="kinu-v2__tab-lbl">1 solo<br>ingrediente</span>
          </button>

          <button class="kinu-v2__tab"
                  data-target="kv-tab-2"
                  role="tab" aria-selected="false" aria-controls="kv-tab-2">
            <span class="kinu-v2__tab-icon">{{ icon_drop }}</span>
            <span class="kinu-v2__tab-lbl">Sin sabor.<br>Sin stevia.</span>
          </button>

          <button class="kinu-v2__tab"
                  data-target="kv-tab-3"
                  role="tab" aria-selected="false" aria-controls="kv-tab-3">
            <span class="kinu-v2__tab-icon">{{ icon_moon }}</span>
            <span class="kinu-v2__tab-lbl">110<br>noches</span>
          </button>

          <button class="kinu-v2__tab"
                  data-target="kv-tab-4"
                  role="tab" aria-selected="false" aria-controls="kv-tab-4">
            <span class="kinu-v2__tab-icon">{{ icon_scale }}</span>
            <span class="kinu-v2__tab-lbl">280mg<br>por porción</span>
          </button>

          <button class="kinu-v2__tab"
                  data-target="kv-tab-5"
                  role="tab" aria-selected="false" aria-controls="kv-tab-5">
            <span class="kinu-v2__tab-icon">{{ icon_hex }}</span>
            <span class="kinu-v2__tab-lbl">Citrato<br>puro</span>
          </button>

        </div><!-- /.kinu-v2__tabs -->

        <!-- Panel de contenido del beneficio activo -->
        <div class="kinu-v2__content-panel" role="region" aria-live="polite">

          <div class="kinu-v2__panel-content is-active" id="kv-tab-1" role="tabpanel">
            <h3 class="kinu-v2__panel-title">1 solo ingrediente</h3>
            <p class="kinu-v2__panel-desc">
              Citrato de magnesio puro. Sin mezclas. Sin rellenos.
              Sabes exactamente qué entra a tu cuerpo.
            </p>
          </div>

          <div class="kinu-v2__panel-content" id="kv-tab-2" role="tabpanel">
            <h3 class="kinu-v2__panel-title">Sin sabor. Sin stevia.</h3>
            <p class="kinu-v2__panel-desc">
              Se disuelve invisible en cualquier líquido.
              Sin comprometer nada — ni el gusto ni la pureza.
            </p>
          </div>

          <div class="kinu-v2__panel-content" id="kv-tab-3" role="tabpanel">
            <h3 class="kinu-v2__panel-title">110 noches</h3>
            <p class="kinu-v2__panel-desc">
              Un tarro. Cuatro meses de ritual nocturno.
              2 g por noche, 110 porciones de calma.
            </p>
          </div>

          <div class="kinu-v2__panel-content" id="kv-tab-4" role="tabpanel">
            <h3 class="kinu-v2__panel-title">280 mg por porción</h3>
            <p class="kinu-v2__panel-desc">
              La dosis respaldada por la ciencia.
              280 mg de magnesio elemental por cada porción de 2 g.
            </p>
          </div>

          <div class="kinu-v2__panel-content" id="kv-tab-5" role="tabpanel">
            <h3 class="kinu-v2__panel-title">Citrato puro</h3>
            <p class="kinu-v2__panel-desc">
              La forma de magnesio con mayor biodisponibilidad.
              Se absorbe más, trabaja mejor. No es marketing: es química.
            </p>
          </div>

        </div><!-- /.kinu-v2__content-panel -->

        <!-- CTAs -->
        <div class="kinu-v2__ctas">
          <a href="{{ product_url }}" class="kinu-v2__cta kinu-v2__cta--primary">
            Quiero mi KINU &nbsp;→
          </a>
          <a href="#kinu-ingredient" class="kinu-v2__cta kinu-v2__cta--secondary">
            Ver el ingrediente ↓
          </a>
        </div>

      </div><!-- /.kinu-v2__content-col -->
    </div><!-- /.kinu-v2__layout -->
  </div><!-- /.kinu-v2__desktop -->

  <!-- ══════════════════════════════════════════════════
       MÓVIL (≤ 768px)
       Spline centrado arriba · grid 2 columnas abajo
       ══════════════════════════════════════════════════ -->
  <div class="kinu-v2__mobile">

    <!-- Spline centrado -->
    <div class="kinu-v2__m-jar">
      <div class="kinu-spline kinu-spline--mobile" id="kinu-spline-mobile">
        <iframe
          src="https://my.spline.design/kinudef-NRPFFaG0qACP6RXXJmzxyEml/"
          frameborder="0"
          loading="lazy"
          title="KINU Magnesio 3D"
        ></iframe>
      </div>
    </div>

    <!-- Grid 2 × N de cards -->
    <div class="kinu-v2__m-grid">

      <div class="kinu-v2__m-attr" data-seq="1">
        <div class="kinu-v2__icon">{{ icon_atom }}</div>
        <h3 class="kinu-v2__title">1 solo ingrediente</h3>
        <p class="kinu-v2__desc">Citrato de magnesio puro. Sin mezclas. Sin rellenos.</p>
      </div>

      <div class="kinu-v2__m-attr" data-seq="2">
        <div class="kinu-v2__icon">{{ icon_drop }}</div>
        <h3 class="kinu-v2__title">Sin sabor. Sin stevia.</h3>
        <p class="kinu-v2__desc">Se disuelve invisible en cualquier líquido.</p>
      </div>

      <div class="kinu-v2__m-attr" data-seq="3">
        <div class="kinu-v2__icon">{{ icon_moon }}</div>
        <h3 class="kinu-v2__title">110 noches</h3>
        <p class="kinu-v2__desc">Un tarro. Cuatro meses de ritual nocturno.</p>
      </div>

      <div class="kinu-v2__m-attr" data-seq="4">
        <div class="kinu-v2__icon">{{ icon_scale }}</div>
        <h3 class="kinu-v2__title">280mg por porción</h3>
        <p class="kinu-v2__desc">La dosis respaldada por la ciencia.</p>
      </div>

      <!-- 5a card: ocupa columna completa -->
      <div class="kinu-v2__m-attr kinu-v2__m-attr--full" data-seq="5">
        <div class="kinu-v2__icon">{{ icon_hex }}</div>
        <h3 class="kinu-v2__title">Citrato puro</h3>
        <p class="kinu-v2__desc">La forma de magnesio con mayor biodisponibilidad.</p>
      </div>

    </div><!-- /.kinu-v2__m-grid -->

  </div><!-- /.kinu-v2__mobile -->

</div><!-- /.kinu-v2 -->

<script>
(function () {
  var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Título: fade-in al entrar al viewport ── */
  var heroTitle = document.querySelector('.js-kv-title');
  if (heroTitle && typeof IntersectionObserver !== 'undefined') {
    var tObs = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        heroTitle.classList.add('is-visible');
        tObs.disconnect();
      }
    }, { threshold: 0.2 });
    tObs.observe(heroTitle);
  } else if (heroTitle) {
    heroTitle.classList.add('is-visible');
  }

  /* ══════════════════════════════════════════════
     DESKTOP — interacción por tabs (clic)
     ══════════════════════════════════════════════ */
  var desktop = document.querySelector('.kinu-v2__desktop');
  if (desktop) {
    var tabs   = Array.prototype.slice.call(desktop.querySelectorAll('.kinu-v2__tab'));
    var panels = Array.prototype.slice.call(desktop.querySelectorAll('.kinu-v2__panel-content'));

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.dataset.target;

        tabs.forEach(function (t) {
          t.classList.remove('is-active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(function (p) { p.classList.remove('is-active'); });

        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        var panel = document.getElementById(target);
        if (panel) panel.classList.add('is-active');
      });
    });
  }

  /* ══════════════════════════════════════════════
     MÓVIL — IntersectionObserver: card activa al entrar
     ══════════════════════════════════════════════ */
  var mobile = document.querySelector('.kinu-v2__mobile');
  var mAttrs = mobile
    ? Array.prototype.slice.call(mobile.querySelectorAll('.kinu-v2__m-attr'))
    : [];

  if (mobile && mAttrs.length) {
    if (REDUCED) {
      mAttrs.forEach(function (a) { a.classList.add('is-active'); });
    } else if (typeof IntersectionObserver !== 'undefined') {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          e.target.classList.toggle('is-active', e.isIntersecting);
        });
      }, { threshold: 0.4, rootMargin: '-5% 0px -5% 0px' });
      mAttrs.forEach(function (a) { obs.observe(a); });
    }
  }
})();
</script>

{% schema %}
{
  "name": "KINU Valor",
  "tag": "section",
  "class": "kinu-valor-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto KINU (para el CTA)"
    }
  ],
  "presets": [{ "name": "KINU Valor" }]
}
{% endschema %}

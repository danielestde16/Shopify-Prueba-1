<link rel="stylesheet" href="{{ 'kinu-valor.css' | asset_url }}" media="print" onload="this.media='all'"><noscript><link rel="stylesheet" href="{{ 'kinu-valor.css' | asset_url }}"></noscript>

<style>
/* ==============================================
   KINU Valor — Layout Collider scroll-swap
   ============================================== */

/* Título protagonista — line-height >= 1 para no cortar descenders */
.kinu-v2__hero-title {
  font-size: clamp(3rem, 7vw, 7rem) !important;
  font-weight: 900 !important;
  line-height: 1.04 !important;
  letter-spacing: -0.05em !important;
  margin-bottom: 28px !important;
  padding-bottom: 4px !important; /* espacio para descenders */
}

/* --- DESKTOP >=769px: sección 2×alto, layout sticky --- */
@media (min-width: 769px) {
  /* Sección tiene 2 alturas de viewport para que haya espacio de scroll */
  .kinu-v2__desktop { height: 200vh; position: relative; }

  /* El layout se queda pegado mientras el usuario scrollea la sección */
  .kinu-v2__layout {
    position: sticky !important;
    top: calc(var(--header-height, 72px) + 2px) !important;
    height: calc(100vh - var(--header-height, 72px) - 4px) !important;
    align-items: stretch !important;
    overflow: hidden;
  }

  /* Columna izquierda: llena el alto del layout */
  .kinu-v2__product-col {
    display: flex !important;
    align-items: center !important;
    height: 100% !important;
  }

  /* Columna derecha: contenedor de los dos paneles */
  .kinu-v2__content-col {
    position: relative !important;
    overflow: hidden !important;
    height: 100% !important;
  }

  /* Paneles superpuestos en el mismo espacio */
  .kinu-v2__panel-a,
  .kinu-v2__panel-b {
    position: absolute !important;
    inset: 0 !important;
    padding: 44px 0 44px 64px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
    overflow-y: auto !important;
    transition: opacity 0.55s ease, transform 0.55s ease !important;
  }

  .kinu-v2__panel-a { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .kinu-v2__panel-b { opacity: 0; transform: translateY(44px); pointer-events: none; }

  .kinu-v2--stats .kinu-v2__panel-a { opacity: 0; transform: translateY(-44px); pointer-events: none; }
  .kinu-v2--stats .kinu-v2__panel-b { opacity: 1; transform: translateY(0); pointer-events: auto; }
}

/* Títulos panel B */
.kinu-v2__panel-b-title {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: clamp(2.4rem, 5vw, 5rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 0.97;
  color: #F0F4FD;
  margin: 0 0 16px;
}
.kinu-v2__panel-b-sub {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: 1.05rem;
  font-weight: 400;
  color: #BACFDD;
  line-height: 1.6;
  margin: 0 0 36px;
  max-width: 420px;
}

/* Stat grid */
.kinu-v2__stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 480px; }

.kinu-v2__stat {
  background: rgba(5, 15, 26, 0.7);
  border: 1px solid rgba(74, 173, 223, 0.28);
  border-radius: 18px;
  padding: 28px 18px 22px;
  display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px;
  position: relative; overflow: hidden;
  opacity: 0; transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.kinu-v2__stat.is-visible { opacity: 1; transform: translateY(0); }
.kinu-v2__stat::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(74,173,223,0.1) 0%, transparent 65%);
  pointer-events: none;
}
.kinu-v2__stat--gold { border-color: rgba(201,168,76,0.38); }
.kinu-v2__stat--gold::before { background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.12) 0%, transparent 65%); }

.kinu-v2__stat-num {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 900; line-height: 1; letter-spacing: -0.03em;
  color: #4AADDF; text-shadow: 0 0 32px rgba(74,173,223,0.5);
}
.kinu-v2__stat--gold .kinu-v2__stat-num { color: #C9A84C; text-shadow: 0 0 32px rgba(201,168,76,0.45); }
.kinu-v2__stat-label { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 12.5px; font-weight: 500; color: #BACFDD; line-height: 1.45; margin: 0; }
.kinu-v2__stat-cite  { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 9.5px; color: rgba(186,207,221,0.4); letter-spacing: 0.03em; }

/* --- MÓVIL --- */
.kinu-v2__m-hero { padding: 48px 20px 0; text-align: center; }
.kinu-v2__m-hero-title {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: clamp(2.4rem, 9vw, 3.4rem); font-weight: 900; letter-spacing: -0.05em; line-height: 0.97;
  color: #F0F4FD; margin: 0 0 12px;
}
.kinu-v2__m-hero-sub { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 1rem; color: #BACFDD; line-height: 1.6; margin: 0; }

.kinu-v2__m-stats { padding: 40px 20px 48px; background: rgba(5, 15, 26, 0.4); }
.kinu-v2__m-stats-title {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  font-size: clamp(1.8rem, 7vw, 2.6rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.0;
  color: #F0F4FD; text-align: center; margin: 0 0 8px;
}
.kinu-v2__m-stats-sub { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 0.95rem; color: #BACFDD; text-align: center; margin: 0 0 24px; line-height: 1.5; }
.kinu-v2__m-stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

@media (max-width: 479px) {
  .kinu-v2__m-stat-grid .kinu-v2__stat { padding: 18px 10px 14px; }
  .kinu-v2__stat-num { font-size: clamp(2.4rem, 10vw, 3.2rem) !important; }
}

@media (prefers-reduced-motion: reduce) {
  .kinu-v2__panel-a, .kinu-v2__panel-b { transition: none !important; }
  .kinu-v2__stat { opacity: 1 !important; transform: none !important; transition: none !important; }
}
</style>


  <circle cx="24" cy="24" r="3.5" fill="currentColor"/>
  <ellipse cx="24" cy="24" rx="18" ry="7" stroke="currentColor" stroke-width="1.5" opacity="0.8"/>
  <ellipse cx="24" cy="24" rx="18" ry="7" stroke="currentColor" stroke-width="1.5" opacity="0.8" transform="rotate(60 24 24)"/>
  <ellipse cx="24" cy="24" rx="18" ry="7" stroke="currentColor" stroke-width="1.5" opacity="0.8" transform="rotate(-60 24 24)"/>
</svg>
{%- endcapture -%}

{%- capture icon_drop -%}
<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
  <path d="M24 6 C24 6 10 22 10 32 A14 14 0 0 0 38 32 C38 22 24 6 24 6Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
  <path d="M16 31 C16 28 15 26 15 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
</svg>
{%- endcapture -%}

{%- capture icon_moon -%}
<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
  <path d="M29 9 A17 17 0 1 0 29 39 A14 14 0 1 1 29 9Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
  <circle cx="36" cy="13" r="1.5" fill="currentColor" opacity="0.6"/>
  <circle cx="40" cy="22" r="1" fill="currentColor" opacity="0.4"/>
</svg>
{%- endcapture -%}

{%- capture icon_scale -%}
<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
  <path d="M6 22 Q5 10 18 10 Q31 10 30 22 Q29 32 18 32 Q7 32 6 22Z" stroke="currentColor" stroke-width="1.5"/>
  <path d="M28 28 C35 33 38 36 43 42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  <circle cx="18" cy="22" r="2.5" fill="currentColor" opacity="0.35"/>
</svg>
{%- endcapture -%}

{%- capture icon_hex -%}
<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
  <polygon points="24,5 40,14 40,32 24,41 8,32 8,14" stroke="currentColor" stroke-width="1.5" fill="none"/>
  <circle cx="24" cy="23" r="3" fill="currentColor"/>
  <line x1="24" y1="5"  x2="24" y2="20" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="40" y1="14" x2="27" y2="21" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="40" y1="32" x2="27" y2="25" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="24" y1="41" x2="24" y2="26" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="8"  y1="32" x2="21" y2="25" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="8"  y1="14" x2="21" y2="21" stroke="currentColor" stroke-width="1" opacity="0.4"/>
</svg>

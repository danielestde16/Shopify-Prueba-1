{%- comment -%}
  Redirige cualquier página de catálogo/colección directo al producto.
  Así "Catálogo" lleva siempre a la página de producto, sin pantalla intermedia.
{%- endcomment -%}
{%- liquid
  if section.settings.product != blank
    assign target = section.settings.product.url
  elsif collections.all.products.first != blank
    assign target = collections.all.products.first.url
  else
    assign target = routes.root_url
  endif
-%}

<script>window.location.replace({{ target | json }});</script>
<meta http-equiv="refresh" content="0;url={{ target }}">

<div style="text-align:center;padding:80px 20px;font-family:'Plus Jakarta Sans',system-ui,sans-serif;color:#0A2540;">
  <a href="{{ target }}" style="color:#1A6FAD;font-weight:700;text-decoration:underline;">Ir al producto →</a>
</div>

{% schema %}
{
  "name": "KINU – Redirección",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto destino",
      "info": "Elige el producto bundle. Si lo dejas vacío usa el primero de la tienda."
    }
  ]
}
{% endschema %}
